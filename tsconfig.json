{
  "compilerOptions": {
    "sourceMap": false,
    "outDir": "./dist",
    "types": [ "node" ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "utils/*": [ "./src/utils/*" ],
      "assets/*": [ "./src/utils/assets/*" ],
      "types/*": ["./src/types/*"]
    },
    "target": "ESNext",
    "jsx": "react",
    "strict": true,
    "lib": [
      "DOM",
      "WebWorker",
      "ESNext.Array",
      "ESNext.AsyncIterable",
      "ES2022.Object",
      "esnext",
      "esnext.String"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true

  },
  "exclude": [
    "node_modules",
  ]
}
